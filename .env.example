# ── Discord ────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# The single server (guild) this bot runs on.
# Slash commands sync instantly when this is set.
GUILD_ID=123456789012345678

# ── OpenRouter (AI) ────────────────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Default model — kept cheap on purpose. Change it live with /model set.
# Cheap picks: deepseek/deepseek-chat, google/gemini-2.0-flash-001, openai/gpt-4o-mini
OPENROUTER_MODEL=deepseek/deepseek-chat

# Optional fallback if the primary model errors out.
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Comma-separated whitelist of models an admin is allowed to switch to.
# Protects you from accidentally selecting an expensive model.
OPENROUTER_ALLOWED_MODELS=deepseek/deepseek-chat,google/gemini-2.0-flash-001,openai/gpt-4o-mini,anthropic/claude-sonnet-4

# Optional: shown to OpenRouter for ranking / analytics.
OPENROUTER_APP_URL=https://octopilotai.com
OPENROUTER_APP_NAME=Octo

# System prompt that shapes Octo's personality.
OCTO_SYSTEM_PROMPT=You are Octo, a friendly and concise Discord assistant. Keep replies short and helpful.

# How many past messages to include as context in a mention conversation.
AI_HISTORY_LIMIT=8

# ── Misc ───────────────────────────────────────────────────
# IANA timezone used for scheduled messages (e.g. Asia/Yangon, UTC).
TIMEZONE=Asia/Yangon

# Path to the SQLite database file.
DATABASE_PATH=octo.db
